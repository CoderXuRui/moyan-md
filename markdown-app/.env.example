# AI Writing Assistant — Built-in Configuration
# Copy this file to .env.local and fill in your API key.
# .env.local is gitignored — never commit your real keys.

# Provider: openai | deepseek | zhipu | siliconflow
VITE_AI_PROVIDER=deepseek

# Your API key (required for AI features to work)
VITE_AI_API_KEY=your-api-key-here

# Optional overrides (defaults are provider-specific)
# VITE_AI_BASE_URL=https://api.deepseek.com/v1
# VITE_AI_MODEL=deepseek-chat
# VITE_AI_ENABLED=true
